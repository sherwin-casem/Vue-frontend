{
  "name": "ocpp-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "npx kendo-ui-license activate --key $KENDO_UI_LICENSE && vue-cli-service build",
    "lint": "vue-cli-service lint",
    "type-check": "vue-tsc --noEmit",
    "build:type-check": "vue-tsc --noEmit && vue-cli-service build"
  },
  "dependencies": {
    "@progress/kendo-data-query": "^1.7.1",
    "@progress/kendo-licensing": "^1.7.0",
    "@progress/kendo-theme-default": "^11.2.0",
    "@progress/kendo-vue-buttons": "^6.4.1",
    "@progress/kendo-vue-excel-export": "^6.4.1",
    "@progress/kendo-vue-grid": "^6.4.1",
    "@progress/kendo-vue-inputs": "^6.4.1",
    "@progress/kendo-vue-pdf": "^6.4.1",
    "axios": "^1.6.2",
    "core-js": "^3.8.3",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "pinia": "^2.1.7",
    "vue": "^3.2.13",
    "vue-i18n": "^9.8.0",
    "vue-router": "^4.0.3",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.4.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@types/file-saver": "^2.0.7",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-plugin-router": "~5.0.0",
    "@vue/cli-plugin-typescript": "^5.0.8",
    "@vue/cli-service": "~5.0.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-vue": "^8.0.3",
    "prettier": "^2.8.8",
    "sass": "^1.32.7",
    "sass-loader": "^12.0.0",
    "typescript": "^5.8.3",
    "vue-tsc": "^3.0.3"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended",
      "@vue/eslint-config-typescript/recommended"
    ],
    "parserOptions": {
      "parser": "@typescript-eslint/parser",
      "ecmaVersion": 2020
    },
    "rules": {
      "@typescript-eslint/no-explicit-any": "warn",
      "@typescript-eslint/no-unused-vars": "warn"
    },
    "overrides": [
      {
        "files": [
          "*.js"
        ],
        "parser": "@babel/eslint-parser",
        "parserOptions": {
          "requireConfigFile": false
        }
      }
    ]
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
