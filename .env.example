# OCPP Frontend Environment Configuration
# Copy this file to .env and update the values for your deployment

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Backend API base URL - Replace with your actual backend URL
VUE_APP_API_BASE_URL=https://your-backend-server/api/v1

# Authentication endpoints
VUE_APP_API_LOGIN_ENDPOINT=/auth/login
VUE_APP_API_LOGOUT_ENDPOINT=/auth/logout
VUE_APP_API_ME_ENDPOINT=/auth/me

# =============================================================================
# BUILD CONFIGURATION
# =============================================================================

# Environment mode (development, production)
NODE_ENV=development

# =============================================================================
# DOCKER CONFIGURATION (for docker-compose deployment)
# =============================================================================

# Port where the frontend will be accessible
FRONTEND_PORT=8080
